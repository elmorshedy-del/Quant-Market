# Optional tuning
APP_NAME=Quant Strategy Tournament (GLM-5 Aligned)
APP_ENV=development
DATA_CACHE_DIR=data/cache

# Data source mode
# Supported: yfinance, polygon, auto
DATA_SOURCE=yfinance
DATA_SOURCE_ALLOW_FALLBACK=true
DATA_SOURCE_FALLBACK_ORDER=polygon,yfinance
DATA_REQUEST_TIMEOUT_SECONDS=30

# Paid provider (Polygon) - required if DATA_SOURCE=polygon
POLYGON_API_KEY=
POLYGON_BASE_URL=https://api.polygon.io
POLYGON_ADJUSTED_BARS=true
POLYGON_REQUEST_LIMIT=50000
POLYGON_RETRY_ATTEMPTS=3
POLYGON_RETRY_BACKOFF_SECONDS=2
POLYGON_RETRY_MAX_SLEEP_SECONDS=30

# API hardening
ALLOWED_ORIGINS=http://localhost:8010
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=10
SHOW_SURVIVORSHIP_WARNING=true

# Backtest defaults
DEFAULT_INITIAL_CAPITAL=100000
DEFAULT_TRADING_COST_BPS=10
DEFAULT_BORROW_COST_BPS_ANNUAL=50
DEFAULT_RISK_FREE_RATE_ANNUAL=0.02
DEFAULT_TARGET_VOL_ANNUAL=0.15
