# Optional tuning
APP_NAME=Quant Strategy Tournament (GLM-5 Aligned)
APP_ENV=development
DATA_CACHE_DIR=data/cache

# Data source mode
# yfinance is free lagged daily data
DATA_SOURCE=yfinance

# Backtest defaults
DEFAULT_INITIAL_CAPITAL=100000
DEFAULT_TRADING_COST_BPS=10
DEFAULT_BORROW_COST_BPS_ANNUAL=50
DEFAULT_RISK_FREE_RATE_ANNUAL=0.02
DEFAULT_TARGET_VOL_ANNUAL=0.15
